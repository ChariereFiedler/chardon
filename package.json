{
  "name": "chardon",
  "version": "0.1.0",
  "type": "module",
  "description": "Workflow monitoring for Claude Code: collection, token-cost analysis, and an improvement loop",
  "license": "MIT",
  "author": "siliceum",
  "homepage": "https://github.com/ChariereFiedler/chardon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChariereFiedler/chardon.git"
  },
  "bugs": {
    "url": "https://github.com/ChariereFiedler/chardon/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "pretest": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check lib/ hooks/ scripts/",
    "lint:fix": "biome check --write lib/ hooks/ scripts/",
    "eval": "vitest run --config vitest.eval.config.ts",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.106.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.28.1",
    "fast-check": "^4.8.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
